# Variables d'environnement pour docker-compose et Coolify.
# Copier ce fichier en `.env` (à la racine) et remplir les valeurs.
# Le `.env` est gitignore.

# === LLM ===
# Clé Groq (compte gratuit : https://console.groq.com)
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.1-8b-instant
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Redaction PII (numéros de colis, emails, téléphones, montants, noms)
# avant tout appel LLM. Restauration côté serveur dans la réponse.
PII_REDACT=true

# === Réseau ===
# URL publique de l'API backend. Bakée dans le bundle frontend au build.
#   Local   : http://localhost:8000
#   Coolify : https://api.assist360.tondomaine.fr
NEXT_PUBLIC_API_URL=http://localhost:8000

# Origines autorisées pour le CORS côté backend (séparées par des virgules)
#   Local   : http://localhost:3000,http://127.0.0.1:3000
#   Coolify : https://assist360.tondomaine.fr
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
