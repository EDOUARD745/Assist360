LLM_PROVIDER=groq
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.1-8b-instant
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Redaction PII avant tout appel LLM (recommandé : true)
PII_REDACT=true

# Origines autorisées pour le CORS (séparées par des virgules)
# En prod : https://assist360.example.com,https://www.assist360.example.com
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Pour basculer sur OpenAI :
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Pour basculer sur Ollama local :
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3.1:8b
